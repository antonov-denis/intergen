const totalScientists = countries.reduce(
  (total, country) => total + country.scientists.length,
  0
);

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
---

<BaseLayout
  title="INTERGEN | Scientists"
  description="Scientists with contribution to INTERGEN."
>
  <PageHeader title="Scientists with contribution to INTERGEN" />

  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="grid gap-8 lg:grid-cols-[0.7fr_1.3fr]">
      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="border border-border bg-muted p-6">
          <p
            class="font-sans text-xs font-semibold uppercase tracking-[0.16em] text-primary"
          >
            Directory
          </p>
          <p class="mt-3 text-4xl font-semibold leading-none text-foreground">
            {totalScientists}
          </p>
          <p class="mt-2 text-sm text-muted-foreground">
            scientists listed across {countries.length} countries
          </p>
          <nav
            class="mt-6 grid gap-2 font-sans text-sm"
            aria-label="Scientist countries"
          >
            {
              countries.map((country) => (
                <a
                  class="flex items-center justify-between gap-3 text-foreground underline hover:text-primary"
                  href={`#${slugify(country.name)}`}
                >
                  <span>{country.name}</span>
                  <span class="text-xs text-muted-foreground">
                    {country.scientists.length}
                  </span>
                </a>
              ))
            }
          </nav>
        </div>
      </aside>

      <div class="space-y-8">
        {
          countries.map((country) => (
            <section
              id={slugify(country.name)}
              class="scroll-mt-28 border border-border bg-card"
            >
              <div class="flex flex-wrap items-end justify-between gap-4 border-b border-border px-6 py-5">
                <div>
                  <p class="font-sans text-xs font-semibold uppercase tracking-[0.16em] text-primary">
                    Country
                  </p>
                  <h2 class="mt-2 text-3xl font-semibold leading-tight text-foreground">
                    {country.name}
                  </h2>
                </div>
              </div>

              <div class="divide-y divide-border">
                {country.scientists.map((scientist) => (
                  <article class="grid gap-4 px-6 py-5 md:grid-cols-[0.8fr_1.2fr]">
                    <div>
                      <h3 class="text-xl font-semibold leading-snug text-foreground">
                        {scientist.url ? (
                          <a
                            class="underline hover:text-primary"
                            href={scientist.url}
                          >
                            {scientist.name}
                          </a>
                        ) : (
                          scientist.name
                        )}
                      </h3>
                      <p class="mt-1 font-sans text-sm text-muted-foreground">
                        {scientist.degree}
                      </p>
                    </div>

                    <div class="space-y-3">
                      <p class="font-sans text-sm font-semibold uppercase tracking-[0.08em] text-foreground">
                        {scientist.institution}
                      </p>
                      <p class="flex flex-wrap gap-x-4 gap-y-2 font-sans text-sm text-muted-foreground">
                        {scientist.emails.map((email) => (
                          <a
                            class="underline hover:text-primary"
                            href={`mailto:${email}`}
                          >
                            {email}
                          </a>
                        ))}
                      </p>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
