---
import EventCarousel from "../components/EventCarousel.astro";
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import newsEvents from "../data/newsEvents.json";

interface NewsEventImage {
  src: string;
  alt: string;
}

interface NewsEvent {
  id: string;
  date: string;
  location?: string;
  title: string;
  paragraphs: string[];
  bullets?: string[];
  images: NewsEventImage[];
}

const events = newsEvents as NewsEvent[];
---

<BaseLayout
  title="INTERGEN | News & Events"
  description="News and events from the INTERGEN academic project."
>
  <PageHeader title="News and Events" />

  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="space-y-10">
      {
        events.map((event) => (
          <article class="grid gap-6 border border-border bg-card p-5 md:grid-cols-[0.9fr_1.1fr] md:p-6">
            <EventCarousel id={event.id} images={event.images} />

            <div class="flex flex-col justify-between gap-6">
              <div>
                <p class="font-sans text-sm font-semibold uppercase tracking-[0.14em] text-primary">
                  {event.date}
                  {event.location ? ` | ${event.location}` : ""}
                </p>
                <h2 class="mt-3 text-3xl font-semibold leading-tight text-foreground">
                  {event.title}
                </h2>
                <div class="mt-5 space-y-4 leading-7 text-muted-foreground">
                  {event.paragraphs.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                  {event.bullets && (
                    <ul class="list-disc space-y-2 pl-5">
                      {event.bullets.map((bullet) => (
                        <li>{bullet}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>

              <p class="font-sans text-sm text-muted-foreground">
                {event.images.length}{" "}
                {event.images.length === 1 ? "image" : "images"}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <div
    class="fixed inset-0 z-50 hidden bg-foreground/90 p-4 backdrop-blur-sm"
    data-fullscreen-viewer
    aria-hidden="true"
  >
    <div class="flex h-full flex-col">
      <div
        class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 pb-4 font-sans text-background"
      >
        <p class="text-sm font-semibold uppercase tracking-[0.14em]">
          Image <span data-fullscreen-current>1</span> / <span
            data-fullscreen-total>1</span
          >
        </p>
        <button
          type="button"
          class="border border-background/40 px-4 py-2 text-sm font-semibold hover:bg-background hover:text-foreground"
          data-fullscreen-close
        >
          Close
        </button>
      </div>
      <div class="relative grid min-h-0 flex-1 place-items-center">
        <img
          src=""
          alt=""
          class="max-h-full [max-width:min(100%,1080px)] border border-background/20 object-contain shadow-2xl"
          data-fullscreen-viewer-image
        />
        <button
          type="button"
          class="absolute left-0 top-1/2 grid size-11 -translate-y-1/2 place-items-center border border-background/40 bg-foreground/60 font-sans text-2xl font-semibold text-background backdrop-blur hover:bg-background hover:text-foreground md:left-4"
          data-fullscreen-prev
          aria-label="Previous fullscreen image"
        >
          ‹
        </button>
        <button
          type="button"
          class="absolute right-0 top-1/2 grid size-11 -translate-y-1/2 place-items-center border border-background/40 bg-foreground/60 font-sans text-2xl font-semibold text-background backdrop-blur hover:bg-background hover:text-foreground md:right-4"
          data-fullscreen-next
          aria-label="Next fullscreen image"
        >
          ›
        </button>
      </div>
    </div>
  </div>

  <script is:inline>
    const fullscreenState = {
      slides: [],
      index: 0,
      showSlide: null,
    };

    const viewer = document.querySelector("[data-fullscreen-viewer]");
    const viewerImage = document.querySelector(
      "[data-fullscreen-viewer-image]"
    );
    const closeButton = document.querySelector("[data-fullscreen-close]");
    const fullscreenPreviousButton = document.querySelector(
      "[data-fullscreen-prev]"
    );
    const fullscreenNextButton = document.querySelector(
      "[data-fullscreen-next]"
    );
    const fullscreenCurrentLabel = document.querySelector(
      "[data-fullscreen-current]"
    );
    const fullscreenTotalLabel = document.querySelector(
      "[data-fullscreen-total]"
    );

    const updateViewerImage = () => {
      if (!viewerImage || !fullscreenState.slides.length) return;

      const activeSlide = fullscreenState.slides[fullscreenState.index];
      viewerImage.setAttribute(
        "src",
        activeSlide.getAttribute("data-fullscreen-image") || ""
      );
      viewerImage.setAttribute(
        "alt",
        activeSlide.getAttribute("data-fullscreen-alt") || ""
      );
      if (fullscreenCurrentLabel) {
        fullscreenCurrentLabel.textContent = String(fullscreenState.index + 1);
      }
      if (fullscreenTotalLabel) {
        fullscreenTotalLabel.textContent = String(
          fullscreenState.slides.length
        );
      }

      const hasMultipleImages = fullscreenState.slides.length > 1;
      fullscreenPreviousButton?.classList.toggle("hidden", !hasMultipleImages);
      fullscreenNextButton?.classList.toggle("hidden", !hasMultipleImages);
    };

    const showFullscreenSlide = (nextIndex) => {
      if (!fullscreenState.slides.length) return;

      fullscreenState.index =
        (nextIndex + fullscreenState.slides.length) %
        fullscreenState.slides.length;
      fullscreenState.showSlide?.(fullscreenState.index);
      updateViewerImage();
    };

    const closeViewer = () => {
      if (!viewer || !viewerImage) return;

      viewer.classList.add("hidden");
      viewer.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      viewerImage.setAttribute("src", "");
      viewerImage.setAttribute("alt", "");
      fullscreenState.slides = [];
      fullscreenState.index = 0;
      fullscreenState.showSlide = null;
    };

    document.querySelectorAll("[data-carousel]").forEach((carousel) => {
      const slides = Array.from(
        carousel.querySelectorAll("[data-carousel-slide]")
      );
      const dots = Array.from(carousel.querySelectorAll("[data-carousel-dot]"));
      const previousButton = carousel.querySelector("[data-carousel-prev]");
      const nextButton = carousel.querySelector("[data-carousel-next]");
      const currentLabel = carousel.querySelector("[data-carousel-current]");
      let currentIndex = 0;

      const showSlide = (nextIndex) => {
        if (!slides.length) return;

        currentIndex = (nextIndex + slides.length) % slides.length;

        slides.forEach((slide, index) => {
          const isActive = index === currentIndex;
          slide.classList.toggle("opacity-100", isActive);
          slide.classList.toggle("opacity-0", !isActive);
          slide.classList.toggle("pointer-events-none", !isActive);
        });

        dots.forEach((dot, index) => {
          dot.classList.toggle("bg-primary", index === currentIndex);
        });

        if (currentLabel) {
          currentLabel.textContent = String(currentIndex + 1);
        }
      };

      previousButton?.addEventListener("click", () =>
        showSlide(currentIndex - 1)
      );
      nextButton?.addEventListener("click", () => showSlide(currentIndex + 1));

      slides.forEach((trigger, index) => {
        trigger.addEventListener("click", () => {
          if (!viewer || !viewerImage) return;

          fullscreenState.slides = slides;
          fullscreenState.index = index;
          fullscreenState.showSlide = showSlide;
          updateViewerImage();
          viewer.classList.remove("hidden");
          viewer.setAttribute("aria-hidden", "false");
          document.body.style.overflow = "hidden";
          closeButton?.focus();
        });
      });
    });

    fullscreenPreviousButton?.addEventListener("click", () =>
      showFullscreenSlide(fullscreenState.index - 1)
    );
    fullscreenNextButton?.addEventListener("click", () =>
      showFullscreenSlide(fullscreenState.index + 1)
    );
    closeButton?.addEventListener("click", closeViewer);
    viewer?.addEventListener("click", (event) => {
      if (event.target === viewer) closeViewer();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeViewer();
      if (!viewer?.classList.contains("hidden") && event.key === "ArrowLeft") {
        showFullscreenSlide(fullscreenState.index - 1);
      }
      if (!viewer?.classList.contains("hidden") && event.key === "ArrowRight") {
        showFullscreenSlide(fullscreenState.index + 1);
      }
    });
  </script>
</BaseLayout>
