---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="font-sans text-sm font-semibold uppercase tracking-[0.14em] text-primary">{eyebrow}</p>}
  <h2 class="mt-2 font-sans text-4xl font-semibold leading-tight text-foreground">{title}</h2>
  {description && <p class="mt-4 leading-7 text-muted-foreground">{description}</p>}
</div>
