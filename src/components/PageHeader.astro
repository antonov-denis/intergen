---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<section class="border-b border-border bg-muted">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <p class="text-sm font-semibold uppercase tracking-[0.14em] text-primary">INTERGEN</p>
    <h1 class="mt-3 text-4xl font-semibold leading-tight text-foreground">{title}</h1>
    {description && <p class="mt-4 max-w-3xl text-lg leading-8 text-muted-foreground">{description}</p>}
  </div>
</section>
