---
import { siteConfig } from "../utils/siteConfig";
---

<section class="border-b border-border bg-background">
  <div class="mx-auto max-w-6xl px-5 py-14 lg:py-18">
    <div class="grid gap-8 border-border md:border-l md:pl-8">
      <div>
        <p class="font-sans text-sm font-semibold uppercase tracking-[0.14em] text-primary">
          INTERGEN · Since {siteConfig.startedAt}
        </p>
        <h1 class="mt-4 max-w-4xl font-serif text-3xl font-semibold leading-tight text-foreground md:text-5xl">
          The intergenerational family businesses as a stress management instrument for entrepreneurs
        </h1>
      </div>

      <div class="max-w-3xl border-t border-border pt-8">
        <h2 class="font-sans text-2xl font-semibold text-foreground">Welcome To INTERGEN Project</h2>
        <p class="mt-4 text-lg leading-8 text-muted-foreground">
          The INTERGEN team would like to welcome you to our website. We will take care to keep you informed about the progress of our project and provide essential information. You are welcome to contribute so we keep it updated.
        </p>
      </div>
    </div>
  </div>
</section>
