---
interface Props {
  title?: string;
  eyebrow?: string;
  class?: string;
}

const { title, eyebrow, class: className = "" } = Astro.props;
---

<article class:list={["border border-border bg-card p-6 text-card-foreground shadow-[0_1px_0_rgba(0,0,0,0.03)]", className]}>
  {eyebrow && <p class="mb-3 text-xs font-semibold uppercase tracking-[0.14em] text-primary">{eyebrow}</p>}
  {title && <h3 class="text-xl font-semibold leading-snug text-foreground">{title}</h3>}
  <div class:list={[title ? "mt-4" : "", "leading-7 text-muted-foreground"]}>
    <slot />
  </div>
</article>
